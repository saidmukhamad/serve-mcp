#!/bin/sh
# Enforces conventional commit prefixes. Wired up by `npm install` (prepare script).
# Release flow: version carries -dev between releases (auto-published to the npm
# `dev` dist-tag by dev-release.yml); `npm version patch` strips it, `npm publish`
# goes to `latest`, [Unreleased] in CHANGELOG.md gets stamped.
msg=$(head -1 "$1")

case "$msg" in
  feat:*|fix:*|docs:*|refactor:*|test:*|chore:*|ci:*) exit 0 ;;
  feat\(*\):*|fix\(*\):*|docs\(*\):*|refactor\(*\):*|test\(*\):*|chore\(*\):*|ci\(*\):*) exit 0 ;;
  Merge*|Revert*|fixup!*|squash!*) exit 0 ;;
esac

echo "commit-msg: first line must start with feat|fix|docs|refactor|test|chore|ci (got: \"$msg\")" >&2
exit 1
