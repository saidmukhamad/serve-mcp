{
  "name": "@saidmukhamad/serve-mcp",
  "version": "0.0.8",
  "description": "Local MCP-controlled artifact shelf: agents publish HTML, Markdown, folders and files; humans get nice preview URLs.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "artifacts",
    "preview",
    "agents"
  ],
  "license": "MIT",
  "author": "saidmukhamad",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saidmukhamad/serve-mcp.git"
  },
  "homepage": "https://github.com/saidmukhamad/serve-mcp#readme",
  "bugs": {
    "url": "https://github.com/saidmukhamad/serve-mcp/issues"
  },
  "type": "module",
  "bin": {
    "serve-mcp": "dist/bin/serve-mcp.js"
  },
  "files": [
    "dist/bin",
    "dist/src"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "start": "node bin/serve-mcp.ts serve",
    "mcp": "node bin/serve-mcp.ts mcp",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "npm run typecheck && node --test \"test/*.test.ts\"",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true",
    "prepublishOnly": "node -e \"const v=require('./package.json').version; if(v.includes('-dev')&&process.env.npm_config_tag!=='dev'){console.error('refusing to publish '+v+' to latest — run npm version patch first (CI ships -dev builds to the dev tag)');process.exit(1)}\" && npm run build"
  },
  "dependencies": {
    "@hono/mcp": "^0.3.0",
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "hono": "^4.7.0",
    "mermaid": "^11.16.0",
    "satteri": "^0.9.4",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "typescript": "^5.9.3"
  }
}
